    "type": "git",
    "url": "git+https://github.com/JayaSaiKishanChapparam/altara.git",
    "directory": "packages/industrial"
  },
  "bugs": {
    "url": "https://github.com/JayaSaiKishanChapparam/altara/issues"
  },
  "keywords": [
    "react",
    "industrial",
    "scada",
    "hmi",
    "manufacturing",
    "process-control",
    "industrial-iot",
    "iiot",
    "oee",
    "spectrogram",
    "fft",
    "vibration-analysis",
    "pid",
    "pid-tuning",
    "alarm-panel",
    "annunciator",
    "trend-recorder",
    "isa-5-1",
    "p-and-id",
    "process-flow-diagram",
    "motor-monitoring",
    "predictive-maintenance",
    "telemetry",
    "real-time",
    "react-components",
    "altara"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
