{
  "name": "@altara/core",
  "version": "0.0.2",
  "description": "React components for real-time telemetry dashboards — built for robotics, aerospace, and industrial IoT.",
  "license": "MIT",
  "author": "Jaya Sai Kishan Chapparam",
  "homepage": "https://github.com/JayaSaiKishanChapparam/altara#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JayaSaiKishanChapparam/altara.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/JayaSaiKishanChapparam/altara/issues"
  },
  "keywords": [
    "react",
    "telemetry",
    "real-time",
    "robotics",
    "ros2",
    "rosbridge",
    "mqtt",
    "iot",
    "aerospace",
    "websocket",
    "canvas",
    "60fps",
    "time-series",
    "gauge",
    "dashboard",
    "visualization"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && cp src/tokens/tokens.css dist/tokens.css",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "leaflet": {
      "optional": true
    },
    "react-leaflet": {
      "optional": true
    },
    "react-grid-layout": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "dependencies": {
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/react": "^15.0.5",
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.3.0",
    "@types/react-grid-layout": "^1.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^1.5.0",
    "happy-dom": "^14.7.1",
    "leaflet": "^1.9.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-grid-layout": "^1.4.4",
    "react-leaflet": "^4.2.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
