{
  "name": "@altara/ros",
  "version": "0.0.1",
  "description": "ROS2 rosbridge adapter for Altara",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@altara/core": "workspace:*",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@altara/core": "workspace:*",
    "@types/react": "^18.3.0",
    "happy-dom": "^14.7.1",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
