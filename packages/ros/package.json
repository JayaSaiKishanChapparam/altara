{
  "name": "@altara/ros",
  "version": "0.0.2",
  "description": "ROS2 rosbridge adapter for React — pipe live sensor_msgs/* topics (IMU, GPS, battery, range, temperature) into real-time Altara dashboards. Typed factories, auto-reconnect, ROS timestamp normalization.",
  "license": "MIT",
  "author": "Jaya Sai Kishan Chapparam",
  "homepage": "https://github.com/JayaSaiKishanChapparam/altara/tree/main/packages/ros#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JayaSaiKishanChapparam/altara.git",
    "directory": "packages/ros"
  },
  "bugs": {
    "url": "https://github.com/JayaSaiKishanChapparam/altara/issues"
  },
  "keywords": [
    "react",
    "ros2",
    "ros",
    "ros-react",
    "react-ros",
    "rosbridge",
    "rosbridge-suite",
    "ros-bridge",
    "robotics",
    "robot-monitoring",
    "robot-dashboard",
    "telemetry",
    "real-time",
    "websocket",
    "sensor-msgs",
    "imu",
    "navsatfix",
    "battery-state",
    "dashboard",
    "monitoring",
    "altara"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@altara/core": "workspace:*",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@altara/core": "workspace:*",
    "@types/react": "^18.3.0",
    "happy-dom": "^14.7.1",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
