{
  "name": "@altara/mqtt",
  "version": "0.1.0",
  "description": "MQTT-over-WebSocket adapter for React — subscribe to MQTT broker topics (sensors, IoT state, telemetry) and pipe live samples into real-time Altara dashboards. JSON / string / binary payloads, topic wildcards, auto-decode.",
  "license": "MIT",
  "author": "Jaya Sai Kishan Chapparam",
  "homepage": "https://github.com/JayaSaiKishanChapparam/altara/tree/main/packages/mqtt#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JayaSaiKishanChapparam/altara.git",
    "directory": "packages/mqtt"
  },
  "bugs": {
    "url": "https://github.com/JayaSaiKishanChapparam/altara/issues"
  },
  "keywords": [
    "react",
    "mqtt",
    "mqtt-react",
    "mqtt-dashboard",
    "iot",
    "iiot",
    "industrial-iot",
    "smart-home",
    "home-automation",
    "scada",
    "hmi",
    "telemetry",
    "real-time",
    "websocket",
    "pub-sub",
    "broker",
    "paho-mqtt",
    "dashboard",
    "monitoring",
    "altara"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@altara/core": "workspace:*",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "mqtt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@altara/core": "workspace:*",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
